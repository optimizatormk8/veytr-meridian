---
import Base from './Base.astro';
import Mermaid from '../components/Mermaid.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  category: string;
  readingTime: number;
  tags: string[];
}

const { title, description, date, author, category, readingTime, tags } = Astro.props;

const formatted = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date.toISOString().slice(0, 10),
  "author": { "@type": "Organization", "name": author },
  "publisher": {
    "@type": "Organization",
    "name": "Meridian",
    "logo": { "@type": "ImageObject", "url": "https://getmeridian.org/img/logo-512.png" },
  },
};
---

<Base title={`${title} — Meridian Blog`} description={description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <main id="main" class="blog-post">
    <article class="blog-article prose" data-pagefind-body>
      <header class="blog-header">
        <a href="/blog/" class="blog-back">&larr; All posts</a>
        <h1>{title}</h1>
        <div class="blog-meta">
          <time datetime={date.toISOString().slice(0, 10)}>{formatted}</time>
          <span class="blog-meta__sep">&middot;</span>
          <span>{author}</span>
          <span class="blog-meta__sep">&middot;</span>
          <span class="blog-category">{category}</span>
          <span class="blog-meta__sep">&middot;</span>
          <span>{readingTime} min read</span>
        </div>
      </header>
      <slot />
    </article>
    <footer class="blog-footer">
      {tags.length > 0 && (
        <div class="blog-tags">
          {tags.map((tag) => (
            <a href={`/blog/tag/${tag}/`} class="blog-tag">#{tag}</a>
          ))}
        </div>
      )}
      <a href="/blog/">&larr; Back to all posts</a>
    </footer>
  </main>
  <Mermaid />
</Base>

<style is:global>
  @import '../styles/prose.css';

  .blog-post {
    max-width: 680px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .blog-back {
    display: inline-block;
    font-size: 0.84rem;
    color: var(--t3);
    text-decoration: none;
    margin-bottom: 24px;
    transition: color 0.12s;
  }
  .blog-back:hover {
    color: var(--ac);
  }

  .blog-header {
    margin-bottom: 40px;
  }
  .blog-header h1 {
    margin-bottom: 12px;
  }
  .blog-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    font-size: 0.84rem;
    color: var(--t3);
  }
  .blog-meta__sep {
    color: var(--b2);
  }
  .blog-category {
    padding: 2px 8px;
    font-size: 0.76rem;
    font-weight: 500;
    background: var(--ac3);
    color: var(--ac);
    border-radius: 4px;
  }

  .blog-footer {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--b1);
  }
  .blog-footer a {
    font-size: 0.88rem;
    color: var(--ac);
    text-decoration: none;
  }
  .blog-footer a:hover {
    text-decoration: underline;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }
  .blog-tag {
    font-size: 0.78rem;
    font-weight: 500;
    padding: 3px 10px;
    background: var(--s1);
    color: var(--t2);
    border: 1px solid var(--b1);
    border-radius: 4px;
    text-decoration: none;
    transition: border-color 0.12s, color 0.12s;
  }
  .blog-tag:hover {
    border-color: var(--ac);
    color: var(--ac);
  }
</style>
