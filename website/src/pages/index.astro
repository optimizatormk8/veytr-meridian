---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import CodeBlock from '../components/CodeBlock.astro';
import Timeline from '../components/Timeline.astro';
import AppGrid from '../components/AppGrid.astro';
import Accordion from '../components/Accordion.astro';
import Callout from '../components/Callout.astro';

const setupSteps = [
  {
    title: 'Installs Docker',
    text: ' and deploys <strong>Xray</strong> (the proxy engine) via the <strong>3x-ui</strong> management panel',
  },
  {
    title: 'Generates x25519 keypair',
    text: ' — unique encryption keys for Reality protocol authentication',
  },
  {
    title: 'Hardens the server',
    text: ' — UFW firewall (ports 22 + 443 only), SSH key-only auth, <strong>BBR</strong> congestion control for faster throughput',
  },
  {
    title: 'Configures VLESS+Reality inbound',
    text: ' on port 443 — the proxy that impersonates a real TLS server',
  },
  {
    title: 'With a domain:',
    text: ' adds HAProxy (TLS SNI routing), Caddy (auto-TLS), and a VLESS+WSS fallback for CDN routing through Cloudflare',
  },
  {
    title: 'Outputs QR codes',
    text: ' and saves an HTML page with connection links, copy buttons, and setup instructions',
  },
];
---

<Base title="Meridian — Censorship-Resistant Proxy">
  <main id="main">
    <Hero />

    <!-- SETUP -->
    <section id="setup">
      <div class="container">
        <div class="section-label">Setup</div>
        <h2>One command</h2>
        <p class="section-desc">
          You need a VPS (Debian/Ubuntu, root SSH key access) and a terminal.
          Run it directly or build a command below.
        </p>

        <CodeBlock code="curl -sSf https://getmeridian.org/install.sh | bash" label="Install the CLI" />

        <div class="or-sep"><span>then</span></div>

        <CodeBlock code="meridian deploy" label="Deploy to your server" />

        <p class="wizard-hint">
          The interactive wizard asks for everything. Or check the
          <a href="/docs/reference/cli-commands/">full CLI reference</a> for flags.
        </p>
      </div>
    </section>

    <hr class="hr" />

    <!-- WHY IT WORKS -->
    <section id="technology">
      <div class="container">
        <div class="section-label">Technology</div>
        <h2>Why it's undetectable</h2>
        <p class="section-desc">
          Censorship systems use three methods to detect proxies.
          Reality defeats all of them.
        </p>

        <Accordion title="Deep Packet Inspection (DPI)" open>
          <p>
            DPI analyzes traffic patterns to identify proxy protocols. VPNs like
            OpenVPN and WireGuard have distinctive packet signatures that are
            trivial to block.
          </p>
          <p>
            <strong>VLESS+Reality</strong> produces traffic that is byte-for-byte
            identical to a normal HTTPS connection. There are no headers, no
            handshake patterns, no packet sizes that distinguish it from regular
            web browsing.
          </p>
        </Accordion>

        <Accordion title="Active probing">
          <p>
            Censors connect to suspicious servers and try to fingerprint them. If
            a server responds differently than the website it claims to be, it
            gets blocked.
          </p>
          <p>
            <strong>Reality</strong> steals the TLS certificate from a real
            website (e.g., microsoft.com). When a probe connects, your server
            completes the TLS handshake using Microsoft's actual certificate. The
            probe sees a legitimate Microsoft server — because, at the TLS level,
            it <em>is</em> one. Only clients with your private key get the proxy
            tunnel.
          </p>
        </Accordion>

        <Accordion title="TLS fingerprinting">
          <p>
            Every TLS client (Chrome, Firefox, curl) sends a unique "Client
            Hello" fingerprint. Censors flag connections where the fingerprint
            doesn't match the claimed application.
          </p>
          <p>
            Meridian uses <strong>uTLS</strong> to impersonate Chrome's exact TLS
            fingerprint — the same one used by billions of devices. Your traffic
            is indistinguishable from someone browsing the web with Chrome.
          </p>
        </Accordion>
      </div>
    </section>

    <hr class="hr" />

    <!-- WHAT HAPPENS -->
    <section id="steps">
      <div class="container">
        <div class="section-label">What happens</div>
        <h2>Setup steps</h2>
        <p class="section-desc">
          The script connects to your server via SSH and configures everything
          automatically.
        </p>

        <Timeline steps={setupSteps} />

        <Callout variant="note" icon="⏱">
          Safe to re-run at any time. Fully idempotent — credentials are
          preserved, settings are updated in place.
        </Callout>
      </div>
    </section>

    <hr class="hr" />

    <!-- CONNECT -->
    <section id="connect">
      <div class="container">
        <div class="section-label">Connect</div>
        <h2>Scan and go</h2>
        <p class="section-desc">
          The script generates an HTML file with a QR code and an "Open in App"
          deep link. Send it to whoever needs it — they tap once and connect.
        </p>

        <AppGrid />

        <Callout variant="warning">
          Device clock must be accurate within 30 seconds. Enable automatic
          date/time in your device settings.
        </Callout>
      </div>
    </section>

    <hr class="hr" />

    <!-- ARCHITECTURE -->
    <section id="architecture">
      <div class="container">
        <div class="section-label">Architecture</div>
        <h2>How it works</h2>

        <div class="arch-diagram">
          <img
            src="/img/architecture.png"
            alt="Meridian architecture — HAProxy SNI routing, Caddy TLS, Xray Reality"
            loading="lazy"
            width="1200"
            height="669"
          />
        </div>

        <Accordion title="Standalone mode (no domain)" open>
          <p>
            <strong>HAProxy</strong> sits on port 443 and routes traffic by TLS
            SNI. Reality connections (SNI = microsoft.com) route to
            <strong>Xray</strong>, while <strong>Caddy</strong> handles
            everything else — serving hosted connection pages with QR codes over
            HTTPS, using a Let's Encrypt IP certificate (auto-renewed every 6
            days). XHTTP transport is also routed through Caddy via path-based
            routing on port 443 — no extra port exposed.
          </p>
          <p>
            The 3x-ui panel is reverse-proxied by Caddy on a secret path —
            accessible via HTTPS, no SSH tunnel needed. Every connection looks
            like normal HTTPS. Only clients with your private key get through to
            the proxy.
          </p>
        </Accordion>

        <Accordion title="Domain mode (CDN fallback)">
          <p>Adds three components on top of the standalone setup:</p>
          <p>
            <strong>HAProxy</strong> sits on port 443 and inspects the TLS SNI
            header (the hostname in the Client Hello) <em>without</em>
            terminating encryption. Reality traffic (SNI = microsoft.com) routes
            to Xray. Domain traffic (SNI = your domain) routes to Caddy.
          </p>
          <p>
            <strong>Caddy</strong> terminates TLS for your domain using automatic
            Let's Encrypt certificates and reverse-proxies the 3x-ui panel on a
            secret path.
          </p>
          <p>
            <strong>VLESS+WSS inbound</strong> provides a CDN fallback path.
            Traffic flows through Cloudflare's CDN to your domain via WebSocket,
            making the connection work even if your server's IP is blocked —
            Cloudflare's IP ranges are too widely used to block.
          </p>
        </Accordion>
      </div>
    </section>

    <hr class="hr" />

    <!-- REFERENCE -->
    <section id="reference">
      <div class="container">
        <div class="section-label">Reference</div>
        <h2>Configuration & operations</h2>

        <Accordion title="Customization">
          <p>All settings are passed as CLI flags to <code>meridian deploy</code>:</p>
          <div class="ref-table-wrap">
            <table class="ref-table">
              <thead>
                <tr><th>Flag</th><th>Default</th><th>Description</th></tr>
              </thead>
              <tbody>
                <tr><td>--sni HOST</td><td>www.microsoft.com</td><td>Site that Reality impersonates</td></tr>
                <tr><td>--domain DOMAIN</td><td>(none)</td><td>Enable domain mode with CDN fallback</td></tr>
                <tr><td>--xhttp</td><td>enabled</td><td>XHTTP transport (routed through port 443 via Caddy)</td></tr>
                <tr><td>--no-xhttp</td><td></td><td>Disable XHTTP transport</td></tr>
                <tr><td>--email EMAIL</td><td>(none)</td><td>Email for TLS certificates (optional)</td></tr>
                <tr><td>--name NAME</td><td>default</td><td>Name for the first client</td></tr>
                <tr><td>--user USER</td><td>root</td><td>SSH user (non-root gets sudo)</td></tr>
                <tr><td>--yes</td><td></td><td>Skip confirmation prompts</td></tr>
              </tbody>
            </table>
          </div>
          <p>
            For optimal stealth, use <code>meridian scan</code> or
            <a href="https://github.com/XTLS/RealiTLScanner">RealiTLScanner</a>
            to find an SNI target near your server's datacenter.
          </p>
        </Accordion>

        <Accordion title="Cloudflare CDN setup (domain mode)">
          <p><strong>Follow this order</strong> to avoid TLS certificate issues:</p>
          <p>
            1. Add domain in Cloudflare, create A record to server IP<br />
            2. Keep cloud icon <strong>grey</strong> ("DNS only") — don't proxy yet<br />
            3. Run <code>meridian deploy</code> — Caddy gets the TLS cert automatically<br />
            4. Switch to <strong>orange cloud</strong> (Proxied)<br />
            5. SSL/TLS → <strong>Full (Strict)</strong>, Network → <strong>Enable WebSockets</strong>
          </p>
          <p>
            Caddy obtains certs via HTTP-01 on port 80. If Cloudflare's "Always
            Use HTTPS" is active, it breaks the challenge. Disable it or add a
            page rule for <code>/.well-known/acme-challenge/*</code>.
          </p>
        </Accordion>

        <Accordion title="Update & maintenance">
          <p>Update Xray and 3x-ui:</p>
          <CodeBlock code={`ssh root@YOUR_SERVER\ncd /opt/3x-ui && docker compose pull && docker compose up -d`} />
          <p>
            Or re-run <code>meridian deploy</code> — it's safe to repeat. Manage
            clients with <code>meridian client add|list|remove</code>.
          </p>
        </Accordion>

        <Accordion title="Pre-flight check">
          <p>Not sure if your server is compatible? Run a pre-flight check first:</p>
          <CodeBlock code="meridian preflight 1.2.3.4" />
          <p>
            Tests SNI target reachability, ASN match, port availability, DNS, OS,
            and disk space — without installing anything.
          </p>
          <p>For optimal SNI stealth, scan your server's network for same-ASN targets:</p>
          <CodeBlock code="meridian scan 1.2.3.4" />
        </Accordion>

        <Accordion title="Troubleshooting">
          <p><strong>Not connecting?</strong> Test if the server is reachable from your device:</p>
          <CodeBlock code="meridian test" />
          <p>
            Or use the <a href="/ping/">web-based ping tool</a> — no install
            needed, works from any device.
          </p>
          <p>
            <strong>Connection fails immediately:</strong> Check device clock is
            accurate within 30 seconds. Enable "Set Automatically" in date/time
            settings.
          </p>
          <p>
            <strong>Connection stops after days:</strong> Server IP may have been
            blocked. Switch to CDN fallback, or get a new IP and re-run.
          </p>
          <p>
            <strong>Slow speeds:</strong> Some hosting IP ranges are throttled.
            Try a different provider or datacenter (Finland, Netherlands, Sweden).
          </p>
          <p>
            <strong>Do NOT</strong> run other protocols (OpenVPN, WireGuard) on
            the same server — it flags the IP.
          </p>
          <p>Get instant AI-powered help (copies a prompt to your clipboard):</p>
          <CodeBlock code="meridian doctor --ai" />
          <p>
            Or collect diagnostics for a
            <a href="https://github.com/uburuntu/meridian/issues">GitHub issue</a>:
          </p>
          <CodeBlock code="meridian doctor" />
        </Accordion>

        <Accordion title="Client management">
          <p>Share access with friends — each gets their own key:</p>
          <CodeBlock code="meridian client add alice" />
          <p>List all clients:</p>
          <CodeBlock code="meridian client list" />
          <p>Revoke a client:</p>
          <CodeBlock code="meridian client remove alice" />
          <p>
            Each client gets a unique connection key. Generates an HTML file with
            QR codes to share. The server IP is auto-detected from saved
            credentials.
          </p>
        </Accordion>

        <Accordion title="Uninstall">
          <p>Remove the proxy from your server:</p>
          <CodeBlock code="meridian teardown" />
          <p>
            Removes the proxy container, configs, and firewall rules. Does
            <strong>not</strong> remove Docker or system packages — those may be
            used by other applications.
          </p>
        </Accordion>

        <Accordion title="Security notes">
          <p>
            Credentials are stored at <code>/etc/meridian/</code> on the server
            (source of truth) and cached locally at
            <code>~/.meridian/credentials/</code>. The panel is reverse-proxied
            by Caddy on a secret HTTPS path in all modes — no SSH tunnel
            required. SSH password auth is disabled. UFW allows only ports 22,
            80, and 443 — all transports (Reality, XHTTP, WSS) run through port
            443.
          </p>
          <p>
            The 3x-ui Docker image is pinned to a tested version. All secrets are
            redacted from terminal output.
          </p>
        </Accordion>
      </div>
    </section>
  </main>
</Base>

<style>
  .or-sep {
    text-align: center;
    color: var(--t3);
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 20px 0;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .or-sep::before,
  .or-sep::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--b1);
  }

  .wizard-hint {
    font-size: 0.82rem;
    color: var(--t3);
    margin-top: 16px;
    line-height: 1.5;
  }
  .wizard-hint a {
    color: var(--ac);
  }

  .arch-diagram {
    border-radius: var(--r2);
    overflow: hidden;
    border: 1px solid var(--b1);
    margin-bottom: 28px;
  }
  .arch-diagram img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Reference table */
  .ref-table-wrap {
    overflow-x: auto;
    margin: 12px 0;
    -webkit-overflow-scrolling: touch;
  }
  .ref-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
  }
  .ref-table th {
    text-align: left;
    color: var(--t3);
    font-weight: 500;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 8px 14px;
    border-bottom: 1px solid var(--b1);
  }
  .ref-table td {
    padding: 8px 14px;
    border-bottom: 1px solid var(--b1);
    color: var(--t2);
    vertical-align: top;
  }
  .ref-table td:first-child {
    color: var(--t1);
    font-family: var(--mono);
    font-size: 0.78rem;
    white-space: nowrap;
  }
  .ref-table tr:last-child td {
    border-bottom: none;
  }

  [dir="rtl"] .ref-table th {
    text-align: right;
  }
</style>
