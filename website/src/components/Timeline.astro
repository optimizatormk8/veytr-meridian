---
/**
 * Timeline — numbered step timeline.
 * Each step is a { number, title, text } item.
 */
interface Step {
  title: string;
  text: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<div class="timeline">
  {steps.map((step, i) => (
    <div class="timeline__item">
      <div class="timeline__number">{i + 1}</div>
      <div class="timeline__content">
        <strong>{step.title}</strong>
        <span set:html={step.text} />
      </div>
    </div>
  ))}
</div>

<style>
  .timeline {
    margin: 24px 0;
  }
  .timeline__item {
    display: flex;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--b1);
    font-size: 0.88rem;
    line-height: 1.55;
  }
  .timeline__item:last-child {
    border-bottom: none;
  }
  .timeline__number {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--ac2);
    border: 1px solid #d4a24e30;
    color: var(--ac);
    font-family: var(--mono);
    font-size: 0.68rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .timeline__content {
    color: var(--t2);
  }
  .timeline__content strong {
    color: var(--t1);
    font-weight: 500;
  }

  [dir="rtl"] .timeline__item {
    flex-direction: row-reverse;
  }
</style>
