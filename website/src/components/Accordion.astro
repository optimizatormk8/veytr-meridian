---
/**
 * Accordion — expandable details/accordion.
 * Uses native <details>/<summary> for no-JS operation.
 */
interface Props {
  title: string;
  open?: boolean;
}

const { title, open = false } = Astro.props;
---

<details class="accordion" open={open || undefined}>
  <summary class="accordion__trigger">
    <span class="accordion__title">{title}</span>
    <svg class="accordion__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </summary>
  <div class="accordion__content">
    <slot />
  </div>
</details>

<style>
  .accordion {
    background: var(--s1);
    border: 1px solid var(--b1);
    border-radius: var(--r);
    margin: 10px 0;
    overflow: hidden;
    transition: border-color 0.1s;
  }

  .accordion:hover {
    border-color: var(--b2);
  }

  .accordion__trigger {
    padding: 16px 20px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--t1);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    transition: background 0.1s;
    user-select: none;
  }
  .accordion__trigger::-webkit-details-marker {
    display: none;
  }

  .accordion__trigger:hover {
    background: var(--s2);
  }

  .accordion__title {
    flex: 1;
  }

  .accordion__chevron {
    color: var(--t3);
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }

  .accordion[open] .accordion__chevron {
    transform: rotate(180deg);
  }

  .accordion__content {
    padding: 0 20px 20px;
    font-size: 0.88rem;
    color: var(--t2);
    line-height: 1.7;
  }

  .accordion__content :global(p) {
    margin-bottom: 12px;
  }
  .accordion__content :global(p:last-child) {
    margin-bottom: 0;
  }

  .accordion__content :global(strong) {
    color: var(--t1);
    font-weight: 500;
  }

  .accordion__content :global(code) {
    font-family: var(--mono);
    font-size: 0.82rem;
    background: var(--bg);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--b1);
  }

  .accordion__content :global(a) {
    color: var(--ac);
  }

  .accordion__content :global(em) {
    font-style: italic;
    color: var(--t1);
  }

  [dir="rtl"] .accordion__trigger {
    flex-direction: row-reverse;
  }
</style>
